# 食べレコ サーバ設定（コピーして .env を作成）
# 本物のAI解析（文字認識＋構造化）に使うキー。未設定ならモックOCRで動作します。

# ▼ Google Gemini（既定・推奨）。Google AI Studio で取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 使用モデル（任意・既定: gemini-2.5-flash）。例: gemini-2.5-pro / gemini-flash-latest
# GEMINI_MODEL=gemini-2.5-flash

# ▼ 代替: Anthropic Claude を使う場合のみ（Google 未設定時に使用）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLAUDE_MODEL=claude-opus-4-8

# APIポート（任意・既定3001）
# PORT=3001

# ───────── テスト公開向けの簡易ガード（任意・未設定なら無効） ─────────
# プレミアム解放(/subscribe)に必要な共有パスワード。友人テスト時のコスト不正利用を防止。
# 設定すると、このコードを入力した人だけがプレミアム（スキャン無制限）を有効化できます。
# PREMIUM_ACCESS_CODE=お好きな合言葉
# 1日あたりの実OCR(Gemini)呼び出し上限。コスト青天井を防ぐ保険（プロセス内カウンタ・日次リセット）。
# DAILY_OCR_LIMIT=200
